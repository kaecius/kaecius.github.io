---
import { getPortfolioData } from '../../portfolio';
import { tReplace } from '../../i18n';

const en = getPortfolioData('en');
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-container">
    <p class="footer-text mono">
      {tReplace('footer.copyright', { year: String(year) }, 'en')}
    </p>
    <div class="footer-links">
      {en.socialLinks.map((link) => (
        <a 
          href={link.url} 
          target="_blank" 
          rel="noopener noreferrer"
          class="footer-link mono invert-hover"
        >
          {link.name}
        </a>
      ))}
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border-subtle);
    padding: var(--space-xl) var(--space-md);
  }

  .footer-container {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .footer-text {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .footer-links {
    display: flex;
    gap: var(--space-sm);
  }

  .footer-link {
    font-size: 0.8rem;
  }

  @media (max-width: 480px) {
    .footer-container {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
