---
import { getPortfolioData } from '../../portfolio';
import { t } from '../../i18n';

const en = getPortfolioData('en');
const es = getPortfolioData('es');
---

<section id="exploring" class="exploring">
  <h2 class="section-title mono" data-i18n="exploring.title">{t('exploring.title', 'en')}</h2>

  <div class="lang-en">
    <div class="exploring-grid">
      {en.currentlyExploring.map((item) => (
        <div class="exploring-item">
          <h3 class="exploring-title mono">{item.title}</h3>
          <p class="exploring-desc">{item.description}</p>
        </div>
      ))}
    </div>
  </div>

  <div class="lang-es">
    <div class="exploring-grid">
      {es.currentlyExploring.map((item) => (
        <div class="exploring-item">
          <h3 class="exploring-title mono">{item.title}</h3>
          <p class="exploring-desc">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .exploring {
    padding: var(--space-3xl) var(--space-md);
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: var(--space-2xl);
    color: var(--color-text);
  }

  .exploring-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-lg);
  }

  .exploring-item {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: 6px;
    padding: var(--space-lg);
    transition: border-color var(--transition-fast);
  }

  .exploring-item:hover {
    border-left-color: var(--color-accent-hover);
  }

  .exploring-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .exploring-desc {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .exploring {
      padding: var(--space-2xl) var(--space-md);
    }

    .exploring-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
