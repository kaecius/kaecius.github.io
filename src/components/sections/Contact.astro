---
import { getPortfolioData } from '../../portfolio';
import { t } from '../../i18n';

const en = getPortfolioData('en');
const es = getPortfolioData('es');
---

<section id="contact" class="contact">
  <h2 class="section-title mono" data-i18n="contact.title">{t('contact.title', 'en')}</h2>
  
  <div class="contact-content">
    <p class="contact-cta" data-i18n="contact.cta">{t('contact.cta', 'en')}</p>
    
    <div class="contact-links lang-en">
      <a 
        href={`mailto:${en.contact.email}`}
        class="contact-link mono invert-hover"
        data-i18n="contact.email"
      >
        {t('contact.email', 'en')}: {en.contact.email}
      </a>
      
      <a 
        href={en.contact.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="contact-link mono invert-hover"
        data-i18n="contact.linkedin"
      >
        {t('contact.linkedin', 'en')}
      </a>
    </div>
    
    <div class="contact-links lang-es">
      <a 
        href={`mailto:${es.contact.email}`}
        class="contact-link mono invert-hover"
        data-i18n="contact.email"
      >
        {t('contact.email', 'es')}: {es.contact.email}
      </a>
      
      <a 
        href={es.contact.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="contact-link mono invert-hover"
        data-i18n="contact.linkedin"
      >
        {t('contact.linkedin', 'es')}
      </a>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: var(--space-3xl) var(--space-md);
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: var(--space-2xl);
    color: var(--color-text);
  }

  .contact-content {
    max-width: 600px;
  }

  .contact-cta {
    font-size: 1.25rem;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .contact-link {
    font-size: 1rem;
    padding: var(--space-sm) var(--space-md);
  }

  @media (max-width: 768px) {
    .contact {
      padding: var(--space-2xl) var(--space-md);
    }

    .contact-cta {
      font-size: 1.1rem;
    }

    .contact-link {
      font-size: 0.9rem;
    }
  }
</style>
